# Copy to .env and fill in. NEVER commit .env (see .gitignore).

# ─── Site ──────────────────────────────────────────────────────────────────
# Canonical site URL (drives sitemap + canonical tags).
# Final production domain is confirmed in Phase 7 (DNS access).
PUBLIC_SITE_URL="https://fwpadvisory.com.au"

# ─── Booking ───────────────────────────────────────────────────────────────
# Discovery Meeting booking link.
# TWO conflicting links exist in the source material — do NOT guess. Leave blank
# until the client confirms the correct one. While blank, booking CTAs fall back
# to /contact. (TODO: confirm correct booking URL.)
PUBLIC_BOOKING_URL=""

# ─── Sanity CMS (Phase 3) ────────────────────────────────────────────────────
PUBLIC_SANITY_PROJECT_ID=""
PUBLIC_SANITY_DATASET="production"
PUBLIC_SANITY_API_VERSION="2024-01-01"
# Server-only token for draft/private content. Never expose to the client.
SANITY_API_READ_TOKEN=""

# ─── Analytics (Phase 6) ─────────────────────────────────────────────────────
# GA4 Measurement ID, e.g. G-XXXXXXXXXX
PUBLIC_GA4_ID=""
# Google Search Console verification token (meta tag content value)
PUBLIC_GSC_VERIFICATION=""
