---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import Button from '../components/ui/Button.astro';
import BookingButton from '../components/BookingButton.astro';
import CredibilityItem from '../components/CredibilityItem.astro';
import LeadMagnet from '../components/LeadMagnet.astro';
import FaqSection from '../components/FaqSection.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { homeFaqs } from '../lib/faqs';
import { faqPageLd } from '../lib/seo';
import {
  ShieldCheck,
  ArrowRight,
  CheckCircle2,
  Scale,
  Building2,
  Users,
  AlertTriangle,
  Briefcase,
  Layers,
  HeartHandshake,
  SearchCheck,
  ClipboardCheck,
} from 'lucide-react';

const heroAssurances = [
  'Understand where your assets may be exposed',
  'Receive a clear, personalised strategy',
  'Coordinate implementation with specialist legal professionals',
];

const audience = [
  { icon: Briefcase, text: 'You own a business, investment assets, or entities that create exposure.' },
  { icon: Layers, text: 'You have trusts, companies, or structures that may no longer match your situation.' },
  { icon: HeartHandshake, text: 'You want wealth passed on clearly, especially in a blended or complex family situation.' },
  { icon: AlertTriangle, text: 'You are concerned about claims, creditors, family disputes, or unintended outcomes.' },
];

const scenarios = [
  { icon: Briefcase, title: 'Business owner exposure', text: 'You own or operate a business and want to reduce the chance that business risks flow through to personal or family assets.' },
  { icon: Layers, title: 'Old trust or company structures', text: 'You have entities that were set up years ago and may no longer reflect your family, asset position, or control objectives.' },
  { icon: HeartHandshake, title: 'Blended family succession', text: 'You want to provide for people fairly while reducing the chance of confusion, conflict, or unintended asset movement.' },
  { icon: Users, title: 'Children and inheritance protection', text: 'You want wealth passed on in a controlled way, rather than exposed to relationship breakdowns, poor decisions, or outside claims.' },
  { icon: Scale, title: 'Claims, creditors, or dispute risk', text: 'You are concerned that assets could become exposed through litigation, guarantees, business pressure, or family conflict.' },
  { icon: SearchCheck, title: 'Second opinion on your current plan', text: 'You already have documents or structures, but you are not sure they still work together or reflect your current wishes.' },
];

const risks = [
  { icon: Scale, title: 'Lawsuits and legal claims' },
  { icon: Building2, title: 'Business risks and creditors' },
  { icon: Users, title: 'Family breakdowns and disputes' },
  { icon: AlertTriangle, title: 'Outdated trust arrangements' },
];

const processSteps = [
  { n: '1', title: 'Discovery Meeting', text: 'You complete a short survey, then we identify where your assets may be exposed and what you want to happen.' },
  { n: '2', title: 'Personalised Strategy Paper', text: 'You receive a clear strategy paper that explains the recommended pathway in plain English.' },
  { n: '3', title: 'Strategy Presentation Meeting', text: 'You review the strategy, ask questions, and decide whether to proceed with implementation.' },
];

const received = [
  'Discovery Meeting and risk discussion',
  'Review of your current structures and intentions',
  'Personalised Strategy Paper in plain English',
  'Strategy Presentation Meeting',
  'Fixed-fee implementation pathway where appropriate',
  'Coordination with specialist legal professionals',
];
---

<BaseLayout
  title="Family Wealth Protection Advisory — Asset Protection & Succession Strategy"
  description="Strategy-led asset protection and succession advice for business owners, families, and asset holders who want clearer structures, reduced exposure, and greater control."
  jsonLd={[faqPageLd(homeFaqs)]}
>
  {/* Hero */}
  <section
    class="relative z-10 mx-auto grid max-w-7xl items-center gap-12 px-6 pb-24 pt-16 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:pb-32 lg:pt-24"
  >
    <div class="animate-fade-up-slow">
      <SectionLabel>Asset protection &amp; succession strategy</SectionLabel>
      <h1 class="max-w-4xl text-5xl font-semibold tracking-tight text-white md:text-7xl">
        Strengthen Your Asset Protection and Succession Strategy
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-white/72">
        For business owners, families, and asset holders who want clearer structures, reduced
        exposure, and greater control over how wealth is managed and passed on.
      </p>
      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <BookingButton />
        <Button variant="secondary" href="/guide">Download Free Guide</Button>
      </div>
      <p class="mt-5 text-sm text-white/50">
        Ready now? Book a Discovery Meeting. Not ready yet? Start with the free guide.
      </p>
    </div>

    <div class="animate-fade-up-slow animate-delay-100 relative">
      <div
        class="rounded-[2rem] border border-[#6FD7E3]/20 bg-white/[0.045] p-7 shadow-2xl shadow-black/30 backdrop-blur"
      >
        <div class="flex items-start justify-between gap-6">
          <div>
            <div class="text-sm font-semibold text-[#6FD7E3]">Strategy-led advice</div>
            <h2 class="mt-3 text-3xl font-semibold text-white">
              Clear direction before implementation.
            </h2>
          </div>
          <ShieldCheck className="h-10 w-10 shrink-0 text-[#6FD7E3]" />
        </div>
        <div class="mt-8 space-y-4">
          {
            heroAssurances.map((item) => (
              <div class="flex items-center gap-3 rounded-2xl bg-[#0E1020]/70 p-4">
                <CheckCircle2 className="h-5 w-5 text-[#6FD7E3]" />
                <span class="text-sm text-white/82">{item}</span>
              </div>
            ))
          }
        </div>
        <div class="mt-8 rounded-2xl border border-[#6FD7E3]/20 bg-[#6FD7E3]/10 p-5">
          <p class="text-sm leading-6 text-white/75">
            Strategic advisors, not lawyers. You receive a clear plan first, then the right
            professionals are coordinated to help implement it properly.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Audience */}
  <section class="relative z-10 px-6 pb-8 lg:px-8">
    <div
      class="mx-auto max-w-7xl rounded-[2rem] border border-[#6FD7E3]/20 bg-[#6FD7E3]/10 p-8 md:p-10"
    >
      <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <SectionLabel>Is this for you?</SectionLabel>
          <h2 class="text-3xl font-semibold tracking-tight text-white md:text-4xl">
            This is for people who need more than a standard will, trust review, or accounting
            conversation.
          </h2>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {
            audience.map(({ icon: Icon, text }) => (
              <div class="rounded-2xl border border-white/10 bg-[#0E1020]/55 p-5">
                <Icon className="mb-4 h-6 w-6 text-[#6FD7E3]" />
                <p class="text-sm leading-6 text-white/75">{text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <LeadMagnet compact />

  {/* Scenarios */}
  <section class="relative z-10 px-6 py-16 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <SectionLabel>Common situations</SectionLabel>
        <h2 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">
          The risk usually becomes obvious after the damage is done.
        </h2>
        <p class="mt-6 text-lg leading-8 text-white/70">
          These are the types of situations where a clear asset protection and succession strategy
          can make the next step easier to understand.
        </p>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          scenarios.map(({ icon: Icon, title, text }) => (
            <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-6">
              <Icon className="mb-5 h-7 w-7 text-[#6FD7E3]" />
              <h3 class="text-lg font-semibold text-white">{title}</h3>
              <p class="mt-3 text-sm leading-6 text-white/65">{text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Risks */}
  <section class="relative z-10 border-y border-white/10 bg-white/[0.025] px-6 py-24 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <h2 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">
          Asset and succession risks are often missed until pressure appears.
        </h2>
        <p class="mt-6 text-lg leading-8 text-white/70">
          The risk is not always obvious. Claims, disputes, outdated structures, and unclear
          succession plans can put control of your assets in someone else’s hands.
        </p>
      </div>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          risks.map(({ icon: Icon, title }) => (
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5 backdrop-blur-sm">
              <Icon className="mb-4 h-6 w-6 text-[#6FD7E3]" />
              <div class="text-sm font-medium text-white">{title}</div>
            </div>
          ))
        }
      </div>
      <div class="mt-12 rounded-3xl border border-[#6FD7E3]/20 bg-[#6FD7E3]/10 p-7">
        <p class="text-xl font-medium text-white">This is not tax planning. This is not accounting.</p>
        <p class="mt-3 text-white/70">
          This is about reducing exposure, improving control, and making sure your intentions are
          clear before problems arise.
        </p>
      </div>
    </div>
  </section>

  {/* Your guide */}
  <section
    class="relative z-10 mx-auto grid max-w-7xl gap-12 px-6 py-24 lg:grid-cols-[0.85fr_1.15fr] lg:px-8"
  >
    <div>
      <SectionLabel>Your guide</SectionLabel>
      <h2 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">
        Good structures should reflect your risks, intentions, and stage of life.
      </h2>
    </div>
    <div class="space-y-6 text-lg leading-8 text-white/70">
      <p>
        You’ve worked hard to build what you have. The question is whether your current structures
        still protect your position and reflect what you want to happen next.
      </p>
      <p>
        Our role is to help you understand the risks, clarify your intentions, and develop a
        strategy that can be implemented with the right legal professionals.
      </p>
      <div class="grid gap-3 sm:grid-cols-3">
        <CredibilityItem>25+ years tax experience</CredibilityItem>
        <CredibilityItem>15+ years financial planning experience</CredibilityItem>
        <CredibilityItem>SAPEPAA-accredited advisor</CredibilityItem>
      </div>
    </div>
  </section>

  {/* The plan */}
  <section class="relative z-10 bg-white/[0.025] px-6 py-24 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <SectionLabel>The plan</SectionLabel>
        <h2 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">
          A clear path from uncertainty to control
        </h2>
        <p class="mt-6 text-lg leading-8 text-white/70">
          You do not need to work out the structure yourself. The process gives you a clear
          sequence: identify the risks, receive the strategy, then decide whether to implement.
        </p>
      </div>
      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        {
          processSteps.map(({ n, title, text }) => (
            <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-7">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-[#6FD7E3] text-sm font-bold text-[#0E1020]">
                {n}
              </div>
              <h3 class="text-xl font-semibold text-white">{title}</h3>
              <p class="mt-3 text-sm leading-6 text-white/70">{text}</p>
            </div>
          ))
        }
      </div>
      <a
        href="/process"
        class="mt-8 inline-flex items-center text-sm font-semibold text-[#6FD7E3] hover:text-[#8FE3EC]"
      >
        View full process <ArrowRight className="ml-2 h-4 w-4" />
      </a>
    </div>
  </section>

  {/* What you receive */}
  <section class="relative z-10 px-6 py-24 lg:px-8">
    <div
      class="mx-auto grid max-w-7xl gap-10 rounded-[2rem] border border-white/10 bg-white/[0.04] p-8 md:p-10 lg:grid-cols-[0.85fr_1.15fr]"
    >
      <div>
        <SectionLabel>What you receive</SectionLabel>
        <h2 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">
          A clear strategy before you commit to implementation.
        </h2>
        <p class="mt-6 text-lg leading-8 text-white/70">
          The aim is to replace uncertainty with a written plan that explains the risks, recommended
          pathway, and next steps.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {
          received.map((item) => (
            <div class="flex gap-3 rounded-2xl border border-[#6FD7E3]/15 bg-[#0E1020]/55 p-5">
              <ClipboardCheck className="mt-0.5 h-5 w-5 shrink-0 text-[#6FD7E3]" />
              <p class="text-sm leading-6 text-white/75">{item}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <LeadMagnet />

  {/* Stakes */}
  <section class="relative z-10 mx-auto grid max-w-7xl gap-6 px-6 py-24 lg:grid-cols-2 lg:px-8">
    <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8">
      <h3 class="text-2xl font-semibold text-white">Without a plan</h3>
      <div class="mt-6 space-y-4 text-white/70">
        <p>• Your assets may be exposed to claims or disputes</p>
        <p>• They may not end up where you intended</p>
        <p>• Decisions may be left to others or to chance</p>
      </div>
    </div>
    <div class="rounded-3xl border border-[#6FD7E3]/25 bg-[#6FD7E3]/10 p-8">
      <h3 class="text-2xl font-semibold text-white">With the right plan</h3>
      <div class="mt-6 space-y-4 text-white/78">
        <p>• Your structures are designed to reduce exposure</p>
        <p>• You stay clearer on who controls what, and when</p>
        <p>• Your intentions are documented before conflict arises</p>
      </div>
    </div>
  </section>

  <FaqSection />
  <FinalCTA />
</BaseLayout>
