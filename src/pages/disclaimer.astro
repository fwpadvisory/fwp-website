---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

// Legal copy is gated: do NOT publish draft text. Final copy comes from the client /
// legal sign-off (CLAUDE.md). This page stays a clearly-marked placeholder.
---

<BaseLayout
  title="Disclaimer — FWP Advisory"
  description="General information disclaimer for the FWP Advisory website."
>
  <PageHero
    label="Disclaimer"
    title="General Information Disclaimer"
    body="This page is awaiting final legal copy and should be reviewed before publication."
    booking={false}
  />
  <section class="relative z-10 mx-auto max-w-4xl px-6 pb-28 lg:px-8">
    <div
      class="space-y-4 rounded-3xl border border-[#6FD7E3]/20 bg-[#6FD7E3]/10 p-8 text-lg leading-8 text-white/70 md:p-10"
    >
      <p class="font-semibold text-white">TODO: awaiting final legal copy.</p>
      <p>
        This page will be populated from the approved disclaimer once signed off. Draft text is not
        published.
      </p>
    </div>
  </section>
</BaseLayout>
