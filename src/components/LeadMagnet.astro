---
import SectionLabel from './ui/SectionLabel.astro';
import BomaForm from './BomaForm.astro';
import { LEAD_MAGNET } from '../lib/site';

// Prototype: LeadMagnetSection. `compact` controls vertical padding.
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section class={`relative z-10 px-6 ${compact ? 'py-8' : 'py-20'} lg:px-8`}>
  <div
    class="mx-auto grid max-w-7xl gap-8 rounded-[2rem] border border-[#6FD7E3]/20 bg-[#6FD7E3]/10 p-8 md:p-10 lg:grid-cols-[0.95fr_1.05fr]"
  >
    <div>
      <SectionLabel>Free guide</SectionLabel>
      <h2 class="text-3xl font-semibold tracking-tight text-white md:text-4xl">
        {LEAD_MAGNET.title}
      </h2>
      <p class="mt-5 text-base leading-7 text-white/70">{LEAD_MAGNET.summary}</p>
    </div>
    <div class="rounded-3xl border border-white/10 bg-[#0E1020]/55 p-6">
      <h3 class="text-xl font-semibold text-white">Get the guide by email</h3>
      <p class="mt-3 text-sm leading-6 text-white/60">
        For people who are interested, but not ready to book a Discovery Meeting yet.
      </p>
      <div class="mt-6">
        <BomaForm layout="inline" submitLabel="Download" />
      </div>
    </div>
  </div>
</section>
