---
interface Props {
  label: string;
  title: string;
  body?: string;
}

const { label, title, body } = Astro.props;
---

<section class="relative z-10 mx-auto max-w-7xl px-6 pb-24 pt-16 lg:px-8 lg:pt-24">
  <div class="mb-4 text-xs font-semibold uppercase tracking-[0.28em] text-aqua">
    {label}
  </div>
  <h1 class="max-w-4xl text-5xl font-semibold tracking-tight text-white md:text-7xl">
    {title}
  </h1>
  {body && <p class="mt-7 max-w-3xl text-lg leading-8 text-white/70">{body}</p>}

  <div
    class="mt-10 inline-flex items-center gap-2 rounded-full border border-aqua/30 bg-aqua/10 px-5 py-2 text-sm font-medium text-soft-aqua"
  >
    <span class="h-2 w-2 rounded-full bg-aqua"></span>
    Phase 1 scaffold — full content lands in Phase 2
  </div>
</section>
