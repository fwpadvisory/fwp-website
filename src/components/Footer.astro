---
import { LEGAL_ITEMS, COMPANY } from '../lib/site';
---

<footer class="relative z-10 border-t border-white/10 px-6 py-10 lg:px-8">
  <div class="mx-auto flex max-w-7xl flex-col gap-8">
    <div class="flex items-center gap-4">
      <img
        src="/sapepaa-certified-adviser.png"
        alt="SAPEPAA Certified Adviser"
        class="h-14 w-auto"
        width="280"
        height="100"
        loading="lazy"
      />
    </div>
    <div
      class="flex flex-col gap-6 text-sm text-white/50 md:flex-row md:items-center md:justify-between"
    >
      <div>&copy; {COMPANY.name}. ABN {COMPANY.abn}.</div>
      <div class="flex flex-wrap gap-5">
        {
          LEGAL_ITEMS.map((item) => (
            <a href={item.href} class="hover:text-white">
              {item.label}
            </a>
          ))
        }
        <span>General information only.</span>
        <span>Not legal or financial advice.</span>
      </div>
    </div>
  </div>
</footer>
