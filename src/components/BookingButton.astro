---
import { ArrowRight } from 'lucide-react';

// Discovery Meeting CTA for static pages.
// Booking link comes from PUBLIC_BOOKING_URL (env). Two conflicting links exist in
// the source material, so we never hardcode one. Until set, the CTA falls back to
// /contact. `data-booking-cta` is the GA4 `booking_click` hook (Phase 6).
interface Props {
  label?: string;
  compact?: boolean;
  arrow?: boolean;
}

const { label = 'Book Your Discovery Meeting', compact = false, arrow = true } = Astro.props;

const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL ?? '';
const href = bookingUrl && bookingUrl.length > 0 ? bookingUrl : '/contact';
const isExternal = href.startsWith('http');

const base =
  'inline-flex items-center justify-center whitespace-nowrap rounded-full bg-[#6FD7E3] font-semibold text-[#0E1020] shadow-lg shadow-[#6FD7E3]/20 transition-all duration-200 hover:-translate-y-0.5 hover:bg-[#8FE3EC]';
const size = compact ? 'px-2.5 py-2 text-sm leading-none lg:px-3.5' : 'px-6 py-3 text-sm';
---

<a
  href={href}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
  class={`${base} ${size}`}
  data-booking-cta
>
  {label}
  {arrow && <ArrowRight className="ml-2 h-4 w-4" />}
</a>
