---
/**
 * BOMA lead-capture form for the free asset-protection guide (used on /guide only).
 *
 * Posts to BOMA's hosted endpoint, which captures + tags the lead, then redirects
 * to /thank-you (set in BOMA: Post-submit -> Send to custom page) where the PDF
 * downloads. We never build a custom backend handler.
 *
 * Render at most once per page: BOMA's embed script (boma-form-submit.js) wires
 * fixed element IDs (#sabr, #g-recaptcha, #boma-form-submit), so a second copy on
 * the same page breaks the anti-bot check ("Identification verification failed").
 */
interface Props {
  consent?: boolean;
  submitLabel?: string;
}

const { consent = true, submitLabel = 'Download Free Guide' } = Astro.props;

const inputClass =
  'w-full rounded-2xl border border-white/10 bg-[#0E1020]/75 px-4 py-3 text-sm text-white outline-none placeholder:text-white/35 focus:border-[#6FD7E3] transition-colors';
const btnClass =
  'inline-flex items-center justify-center whitespace-nowrap rounded-full bg-[#6FD7E3] px-6 py-3 text-sm font-semibold text-[#0E1020] shadow-lg shadow-[#6FD7E3]/20 transition-all duration-200 hover:-translate-y-0.5 hover:bg-[#8FE3EC] disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:translate-y-0';
---

<div data-boma-form>
  <script is:inline src="https://www.google.com/recaptcha/api.js" async defer></script>
  <script is:inline src="https://assets.bomamarketing.com/public/boma-form-submit.js"></script>

  <form action="https://public2.bomamarketing.com/lp/KBL0fB7V" method="post" data-boma-guide>
    <div class="grid gap-4">
      <div>
        <label for="firstName" class="mb-1.5 block text-sm font-medium text-white/80">First name *</label>
        <input type="text" id="firstName" name="firstName" required placeholder="Your first name" class={inputClass} />
      </div>
      <div>
        <label for="email" class="mb-1.5 block text-sm font-medium text-white/80">Email *</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" class={inputClass} />
      </div>
      {consent && (
        <p class="text-xs leading-5 text-white/45">
          You may also receive occasional related insights from FWP Advisory about asset
          protection, succession planning, and family wealth strategy. You can unsubscribe
          at any time.
        </p>
      )}
      <div class="my-2">
        <div class="g-recaptcha" data-sitekey="6Ld2WWQUAAAAAGXM4DhsYHx1glA875PZIjgQpN00" data-theme="dark" data-size="normal" data-callback="allowSubmit" data-expired-callback="denySubmit" data-error-callback="denySubmit"></div>
      </div>
      <div class="invisible"><input class="invisible" id="sabr" name="sabr" /></div>
      <input type="submit" id="boma-form-submit" value={submitLabel} class={btnClass} disabled />
    </div>
  </form>

  <script is:inline>
    document.querySelectorAll('form[data-boma-guide]').forEach(function (f) {
      f.addEventListener('submit', function () {
        if (typeof gtag === 'function') gtag('event', 'guide_form_submit', { event_category: 'conversion' });
      });
    });
  </script>
</div>
