---
import BookingButton from './BookingButton.astro';

// Closing call-to-action (prototype: FinalCTA).
---

<section class="relative z-10 px-6 pb-28 lg:px-8">
  <div
    class="mx-auto max-w-5xl rounded-[2rem] border border-[#6FD7E3]/20 bg-[#6FD7E3]/10 p-10 text-center shadow-2xl shadow-black/20 md:p-14"
  >
    <h2 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">
      Start With a Clear Strategy Conversation
    </h2>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-white/70">
      Book a Discovery Meeting to understand whether an asset protection and succession
      strategy is appropriate for your circumstances.
    </p>
    <div class="mt-9"><BookingButton /></div>
  </div>
</section>
